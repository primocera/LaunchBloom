# -----------------------------------------------------------------------
# OfferFlow AI Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# -----------------------------------------------------------------------

# Server
PORT=3002
NODE_ENV=development

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------
# Stripe — Dashboard → Developers → API keys
# -----------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# OfferFlow price IDs (create in Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# -----------------------------------------------------------------------
# Supabase — Dashboard → Project Settings → API
# Use a SEPARATE Supabase project from ConversionForge (own tables/buckets).
# -----------------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
# service_role key (bypasses RLS) — keep strictly server-side
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------
# Anthropic — console.anthropic.com → API keys
# Powers positioning / offers / launch-kit generation
# -----------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------
# Auth — HMAC session signing (same pattern as ConversionForge)
# -----------------------------------------------------------------------
SESSION_SECRET=

# -----------------------------------------------------------------------
# Resend (optional — transactional emails: welcome, receipts)
# -----------------------------------------------------------------------
RESEND_API_KEY=
