# -----------------------------------------------------------------------
# LaunchBloom Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# -----------------------------------------------------------------------

# Server
PORT=3002
NODE_ENV=development

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Public base URL of the deployed app (used for Stripe success/cancel redirects).
# Falls back to the request Origin header when empty.
PUBLIC_URL=

# -----------------------------------------------------------------------
# Brand identity (optional overrides — see backend/lib/brand.js)
# Defaults use the LaunchBloom brand. Set these per-deploy instead of
# hardcoding a domain anywhere. Sender email must be a verified Resend domain.
# -----------------------------------------------------------------------
BRAND_NAME=LaunchBloom
BRAND_URL=https://launchbloom.app
BRAND_SUPPORT_EMAIL=support@launchbloom.app
BRAND_SENDER_NAME=LaunchBloom
BRAND_SENDER_EMAIL=hello@launchbloom.app
BRAND_LEGAL_NAME=

# -----------------------------------------------------------------------
# Stripe — Dashboard → Developers → API keys
# -----------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
#
# Subscription price IDs — create one recurring Price per cell in Stripe →
# Products (starter/pro/studio × monthly/yearly), then paste the price_... IDs.
# A 3-day free trial is added in code for first-time subscribers only, so keep
# these as plain recurring prices (do NOT configure a trial on the Stripe price).
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_STUDIO_MONTHLY=
STRIPE_PRICE_STUDIO_YEARLY=
#
# Legacy single-price vars (optional) — still honored for old accounts.
# STRIPE_PRICE_BUSINESS resolves to the "studio" plan.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# -----------------------------------------------------------------------
# Supabase — Dashboard → Project Settings → API
# Use a SEPARATE Supabase project from ConversionForge (own tables/buckets).
# -----------------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
# service_role key (bypasses RLS) — keep strictly server-side
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------
# Anthropic — console.anthropic.com → API keys
# Powers positioning / offers / launch-kit generation.
# Leave ANTHROPIC_API_KEY empty for free MOCK mode (schema-generated sample data).
# ANTHROPIC_MODEL picks cost vs quality (all support structured output):
#   claude-opus-4-8 (default, ~$0.40/kit) | claude-sonnet-5 (~$0.17) | claude-haiku-4-5 (~$0.08)
# -----------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5
# Safety ceiling: max real AI calls per day for the WHOLE app (default 300 ≈ ~$3/day).
# A launch kit is ~7 calls, so 300/day ≈ ~40 kits. Blocks abuse / runaway loops.
MAX_AI_CALLS_PER_DAY=300

# -----------------------------------------------------------------------
# Auth — HMAC session signing (same pattern as ConversionForge)
# -----------------------------------------------------------------------
SESSION_SECRET=

# -----------------------------------------------------------------------
# Resend (optional — transactional emails: welcome, receipts)
# -----------------------------------------------------------------------
RESEND_API_KEY=
