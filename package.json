{
  "name": "scalvya",
  "version": "1.0.0",
  "description": "Scalvya — Vite frontend + Express API on Vercel (serverless)",
  "private": true,
  "scripts": {
    "dev": "node --watch backend/server.js",
    "dev:app": "vite",
    "_comment_build": "Deliberately NOT named 'build': Vercel auto-detects a build script, runs it, then fails looking for dist/. The app/ output is committed and served statically instead.",
    "build:app": "vite build",
    "lint": "eslint backend app-src api",
    "test": "node --test \"backend/tests/*.test.js\"",
    "test:unit": "node --test \"backend/tests/*.test.js\"",
    "test:integration": "node --test \"backend/tests/*.test.js\"",
    "_comment_e2e": "Playwright runs LOCALLY (not in CI — CI stays lean by design). One-time setup: npx playwright install chromium",
    "test:e2e": "playwright test",
    "check:app-fresh": "node scripts/check-app-fresh.mjs",
    "check": "npm run lint && npm test && npm run build:app && npm run check:app-fresh",
    "release:check": "node backend/scripts/release-check.js",
    "backfill:consistency": "node backend/scripts/backfill-consistency.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "resend": "^6.12.2",
    "stripe": "^14.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "supertest": "^7.2.2",
    "vite": "^5.4.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
